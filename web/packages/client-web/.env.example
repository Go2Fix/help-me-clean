# ─── API ──────────────────────────────────────────────────────────────────────
VITE_GRAPHQL_ENDPOINT=http://localhost:8080/query

# ─── Authentication ───────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=

# ─── Maps ─────────────────────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

# ─── Payments ─────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── Analytics (set in Vercel for production only) ────────────────────────────
# Set VITE_ENABLE_ANALYTICS=true only on deployments where Vercel Analytics is enabled
# in the Vercel dashboard (go2fix.ro production). Leave unset on staging/dev.
VITE_ENABLE_ANALYTICS=
VITE_GA4_MEASUREMENT_ID=
VITE_META_PIXEL_ID=
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
VITE_CLARITY_ID=
