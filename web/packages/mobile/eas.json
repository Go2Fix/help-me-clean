{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": { "API_URL": "https://dev.api.go2fix.ro/graphql" }
    },
    "staging": {
      "distribution": "internal",
      "env": { "API_URL": "https://dev.api.go2fix.ro/graphql" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "API_URL": "https://api.go2fix.ro/graphql" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "team@go2fix.ro",
        "ascAppId": ""
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      }
    }
  }
}
