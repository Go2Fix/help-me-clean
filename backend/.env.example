# Server
PORT=8080
ENVIRONMENT=development  # development, test, or production

# Database
DATABASE_URL=postgresql://go2fix:password@localhost:5432/go2fix?sslmode=disable

# Auth
GOOGLE_CLIENT_ID=your-google-client-id
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/firma/setari?stripe=complete
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/firma/setari?stripe=refresh

# Keez.ro (Invoicing / Accounting)
# Credentials provided by Keez when they register Go2Fix SRL as an API client
KEEZ_CLIENT_EID=your-keez-client-eid
KEEZ_APPLICATION_ID=your-keez-application-id
KEEZ_SECRET=your-keez-secret
# Invoice series — must be pre-configured in Keez platform (default: FCT)
KEEZ_SERIES=FCT

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Storage (Auto: local for dev, GCS for production)
# For local development: Leave commented to use ./uploads directory
# For GCS: Uncomment and set path to service account key
# GCS_BUCKET=go2fix-dev-uploads
# GCS_PROJECT_ID=go2fix
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/go2fix-dev-key.json

# Security (Phase 2+)
# Cookie domain for production (e.g., .go2fix.ro for cross-subdomain)
# COOKIE_DOMAIN=.go2fix.ro

# CSRF Protection (32-byte secret required)
# CSRF_SECRET=generate-a-32-byte-random-string-here

# Rate Limiting
# RATE_LIMIT_PER_MINUTE=100
# RATE_LIMIT_STRICT_PER_MINUTE=10

# GraphQL Security (Phase 4)
# GRAPHQL_MAX_DEPTH=10
# GRAPHQL_MAX_COMPLEXITY=100

# File Upload Security (Phase 4)
# MAX_FILE_SIZE=10485760  # 10MB in bytes

# Error Handling (Phase 4)
# ERROR_STRICT_MODE=false  # Set true to remove error paths in production

# Email / Notifications (Resend — resend.com)
# In development all emails are skipped; devCode is returned for OTP instead.
# In production set RESEND_API_KEY — all other vars are optional (sensible defaults apply).
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=Go2Fix <noreply@go2fix.ro>

# Resend Template IDs — create each template in dashboard.resend.com, paste IDs below.
# Leave blank to use the built-in branded HTML fallback templates.
RESEND_TEMPLATE_OTP=
RESEND_TEMPLATE_WELCOME_CLIENT=
RESEND_TEMPLATE_WELCOME_COMPANY=
RESEND_TEMPLATE_WELCOME_WORKER=
RESEND_TEMPLATE_ONBOARDING_DAY3=
RESEND_TEMPLATE_ONBOARDING_DAY7=
RESEND_TEMPLATE_BOOKING_CONFIRMATION=
RESEND_TEMPLATE_BOOKING_NEW_COMPANY=
RESEND_TEMPLATE_BOOKING_WORKER_ASSIGNED_CLIENT=
RESEND_TEMPLATE_BOOKING_WORKER_ASSIGNED_WORKER=
RESEND_TEMPLATE_BOOKING_COMPLETED=
RESEND_TEMPLATE_BOOKING_CANCELLED_CLIENT=
RESEND_TEMPLATE_BOOKING_CANCELLED_COMPANY=
RESEND_TEMPLATE_BOOKING_RESCHEDULED=
RESEND_TEMPLATE_COMPANY_APPLICATION=
RESEND_TEMPLATE_COMPANY_APPROVED=
RESEND_TEMPLATE_COMPANY_REJECTED=
RESEND_TEMPLATE_COMPANY_SUSPENDED=
RESEND_TEMPLATE_WORKER_INVITATION=
RESEND_TEMPLATE_INVOICE_READY=
RESEND_TEMPLATE_WAITLIST_CONFIRMATION=
RESEND_TEMPLATE_ACCOUNT_SUSPENDED=

# Slack Notifications (Incoming Webhooks — api.slack.com/messaging/webhooks)
# Dev: all events go to a single channel (#go2fix-dev). Set only SLACK_WEBHOOK_DEV locally.
# Production: one webhook per channel. Leave blank to skip that channel silently.
# SLACK_WEBHOOK_DEV=https://hooks.slack.com/services/xxx/xxx/xxx
# SLACK_WEBHOOK_BOOKINGS=https://hooks.slack.com/services/xxx/xxx/xxx
# SLACK_WEBHOOK_COMPANIES=https://hooks.slack.com/services/xxx/xxx/xxx
# SLACK_WEBHOOK_WORKERS=https://hooks.slack.com/services/xxx/xxx/xxx
# SLACK_WEBHOOK_REVENUE=https://hooks.slack.com/services/xxx/xxx/xxx
# SLACK_WEBHOOK_GROWTH=https://hooks.slack.com/services/xxx/xxx/xxx

# AI / LLM Integration (for personality insights)
#LLM_GEMINI_API_KEY=your-google-gemini-api-key
