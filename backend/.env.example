# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=

# ─── Authentication ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
JWT_SECRET=

# ─── Storage (Google Cloud Storage) ──────────────────────────────────────────
GCS_BUCKET=
GCS_PROJECT_ID=
# Path to service account JSON key file, or leave empty to use ADC
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/firma/setari?stripe=complete
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/firma/setari?stripe=refresh

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Go2Fix <noreply@go2fix.ro>
# Optional: Resend template IDs (leave blank to use built-in HTML fallbacks)
RESEND_TEMPLATE_OTP=
RESEND_TEMPLATE_WELCOME_CLIENT=
RESEND_TEMPLATE_WELCOME_COMPANY=
RESEND_TEMPLATE_WELCOME_WORKER=
RESEND_TEMPLATE_ONBOARDING_DAY3=
RESEND_TEMPLATE_ONBOARDING_DAY7=
RESEND_TEMPLATE_BOOKING_CONFIRMATION=
RESEND_TEMPLATE_BOOKING_NEW_COMPANY=
RESEND_TEMPLATE_BOOKING_WORKER_ASSIGNED_CLIENT=
RESEND_TEMPLATE_BOOKING_WORKER_ASSIGNED_WORKER=
RESEND_TEMPLATE_BOOKING_COMPLETED=
RESEND_TEMPLATE_BOOKING_CANCELLED_CLIENT=
RESEND_TEMPLATE_BOOKING_CANCELLED_COMPANY=
RESEND_TEMPLATE_BOOKING_RESCHEDULED=
RESEND_TEMPLATE_COMPANY_APPLICATION=
RESEND_TEMPLATE_COMPANY_APPROVED=
RESEND_TEMPLATE_COMPANY_REJECTED=
RESEND_TEMPLATE_COMPANY_SUSPENDED=
RESEND_TEMPLATE_WORKER_INVITATION=
RESEND_TEMPLATE_INVOICE_READY=
RESEND_TEMPLATE_WAITLIST_CONFIRMATION=
RESEND_TEMPLATE_ACCOUNT_SUSPENDED=

# ─── WhatsApp Business (Meta) ─────────────────────────────────────────────────
# Webhook URL to register: https://api.go2fix.ro/webhook/whatsapp
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Slack Notifications ──────────────────────────────────────────────────────
# Dev: single webhook for all events. Production: one per channel.
SLACK_WEBHOOK_DEV=
SLACK_WEBHOOK_BOOKINGS=
SLACK_WEBHOOK_COMPANIES=
SLACK_WEBHOOK_WORKERS=
SLACK_WEBHOOK_REVENUE=
SLACK_WEBHOOK_GROWTH=

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
LLM_GEMINI_API_KEY=

# ─── Keez.ro (Invoicing / Accounting) ────────────────────────────────────────
KEEZ_CLIENT_EID=
KEEZ_APPLICATION_ID=
KEEZ_SECRET=
KEEZ_SERIES=FCT

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_KEY=
