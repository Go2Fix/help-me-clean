# Server
PORT=8080
ENVIRONMENT=development  # development, test, or production

# Database
DATABASE_URL=postgresql://go2fix:password@localhost:5432/go2fix?sslmode=disable

# Auth
GOOGLE_CLIENT_ID=your-google-client-id
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/firma/setari?stripe=complete
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/firma/setari?stripe=refresh

# Factureaza.ro (Invoicing)
FACTUREAZA_API_URL=https://sandbox.factureaza.ro/api/v1/
FACTUREAZA_API_KEY=your-factureaza-api-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Storage (Auto: local for dev, GCS for production)
# For local development: Leave commented to use ./uploads directory
# For GCS: Uncomment and set path to service account key
# GCS_BUCKET=go2fix-dev-uploads
# GCS_PROJECT_ID=go2fix
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/go2fix-dev-key.json

# Security (Phase 2+)
# Cookie domain for production (e.g., .go2fix.ro for cross-subdomain)
# COOKIE_DOMAIN=.go2fix.ro

# CSRF Protection (32-byte secret required)
# CSRF_SECRET=generate-a-32-byte-random-string-here

# Rate Limiting
# RATE_LIMIT_PER_MINUTE=100
# RATE_LIMIT_STRICT_PER_MINUTE=10

# GraphQL Security (Phase 4)
# GRAPHQL_MAX_DEPTH=10
# GRAPHQL_MAX_COMPLEXITY=100

# File Upload Security (Phase 4)
# MAX_FILE_SIZE=10485760  # 10MB in bytes

# Error Handling (Phase 4)
# ERROR_STRICT_MODE=false  # Set true to remove error paths in production

# Email / SMTP (for OTP authentication)
# Leave blank in development — devCode is returned in the API response instead.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@go2fix.ro
# SMTP_PASS=your-app-password
# SENDER_EMAIL=noreply@go2fix.ro

# AI / LLM Integration (for personality insights)
#LLM_GEMINI_API_KEY=your-google-gemini-api-key
